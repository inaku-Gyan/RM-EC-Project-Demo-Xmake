# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*:Zone.Identifier
desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
*.swp
*.swo
*.suo
*.user
.idea/

# VSCode — track shared project config, ignore per-user overrides
.vscode/*
!.vscode/settings.example.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ─── Build outputs ────────────────────────────────────────────────────────────
/build/

# ─── Xmake cache (machine-local configuration) ────────────────────────────────
# .xmake/ holds the saved toolchain SDK path and object cache.
# Each developer runs: xmake f -p cross -a arm --sdk=<GNU-tools-for-STM32>
.xmake/

# ─── LSP / clangd ─────────────────────────────────────────────────────────────
# compile_commands.json is generated by: xmake project -k compile_commands
# It contains absolute machine-local paths — do not commit.
compile_commands.json
.cache/

# ─── STM32CubeMX ──────────────────────────────────────────────────────────────
# CubeMX can regenerate its own Makefile; we use xmake instead.
/bsp/CubeMX/Makefile
/bsp/CubeMX/build/

# ─── Toolchain output artefacts (if generated outside /build) ─────────────────
*.elf
*.hex
*.bin
*.map
*.lst

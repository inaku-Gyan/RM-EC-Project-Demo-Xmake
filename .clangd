# clangd project configuration.
# compile_commands.json is generated by: xmake project -k compile_commands
# It lives in the project root so clangd finds it automatically.

CompileFlags:
  # compile_commands.json already carries all -I / -D / -mcpu flags from xmake.
  # clangd needs to query arm-none-eabi-g++ for its built-in system includes;
  # set --query-driver in your editor (see .vscode/settings.json).
  Add:
    # Silence unknown-attribute warnings that clang raises for GCC-specific attrs
    # used in STM32 HAL headers (e.g. __attribute__((packed, aligned(...)))).
    - -Wno-unknown-attributes
    - -Wno-ignored-attributes

---
# Suppress all diagnostics for CubeMX-generated and third-party BSP code.
# We only want clean error reporting in src/ and lib/ecx/.
If:
  PathMatch:
    - bsp/.*
Diagnostics:
  Suppress: "*"
  UnusedIncludes: None

---
# ecx and src: full diagnostics, but relax a few clangd-specific false positives
# that arise from embedded cross-compilation conventions.
If:
  PathMatch:
    - src/.*
    - lib/ecx/.*
Diagnostics:
  UnusedIncludes: Strict
  # CMSIS __DSP_PRESENT etc. appear undefined in clangd analysis — suppress
  # only the ones that are definitively false positives in an MCU context.
  Suppress:
    - pp_including_mainfile_in_preamble
